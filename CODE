from pyspark.sql import SparkSession from pyspark.sql.functions import (
col, sum, avg, count, max, min, stddev, hour, dayofmonth, month, year, to_timestamp, when,
approx_count_distinct, dense_rank, row_number, percentile_approx
)
from pyspark.sql.window import Window
spark = SparkSession.builder \
.appName("Telecom1GBBigDataProject") \
.config("spark.sql.shuffle.partitions", "200") \
.getOrCreate()

# Read Data
cdr = spark.read.option("header", "true") \
.option("inferSchema", "true") \
.csv("telecom_cdr_1gb.csv")
# Cleaning
cdr = cdr.dropna()
cdr = cdr.withColumn("event_time", to_timestamp("event_time"))

# Feature Engineering
cdr = cdr.withColumn("hour", hour("event_time"))
cdr = cdr.withColumn("day", dayofmonth("event_time")) cdr = cdr.withColumn("month", month("event_time")) cdr = cdr.withColumn("year", year("event_time"))

# Cache cdr.cache()

# Operator KPIs
operator_kpis = cdr.groupBy("operator").agg( sum("charge").alias("total_revenue"), approx_count_distinct("msisdn").alias("users"), avg("charge").alias("avg_charge"),
max("charge").alias("max_charge"), min("charge").alias("min_charge"), stddev("charge").alias("std_charge")
)
operator_kpis = operator_kpis.withColumn( "arpu", col("total_revenue") / col("users")
)
# Network Quality
drop_rate_operator = cdr.groupBy("operator") \
.agg(avg("call_drop").alias("drop_rate"))

drop_rate_circle = cdr.groupBy("circle") \
.agg(avg("call_drop").alias("drop_rate"))

# Time Analysis
peak_hours = cdr.groupBy("hour") \
.agg(count("*").alias("events")) \
.orderBy(col("events").desc())
monthly_usage = cdr.groupBy("year", "month") \
.agg(count("*").alias("events"))
# Call Type Analysis
call_type_dist = cdr.groupBy("call_type") \
.agg(count("*").alias("count"),
sum("charge").alias("revenue"))
# Heavy Users
heavy_users = cdr.groupBy("msisdn").agg( sum("data_mb").alias("total_data"), sum("charge").alias("revenue")
).filter(
(col("total_data") > 100000) & (col("revenue") < 500)
)
# Usage Category
cdr = cdr.withColumn(
"usage_category", when(col("data_mb") > 2000, "HIGH")
.when(col("data_mb") > 500, "MEDIUM")
.otherwise("LOW")
)
usage_category_dist = cdr.groupBy("usage_category") \
.agg(count("*").alias("count"))
# Window Functions
user_spend = cdr.groupBy("operator", "msisdn") \
.agg(sum("charge").alias("spent"))
window = Window.partitionBy("operator").orderBy(col("spent").desc()) top_users = user_spend.withColumn(
"rank", dense_rank().over(window)
).filter(col("rank") <= 5)

# Statistical Analysis median_charge = cdr.select(
percentile_approx("charge", 0.5).alias("median_charge")
)
p90_charge = cdr.select(
percentile_approx("charge", 0.9).alias("p90_charge")
)
# Repartition & Heavy Aggregation cdr_rep = cdr.repartition("operator")
operator_event_count = cdr_rep.groupBy("operator") \
.agg(count("*").alias("event_count")) operator_event_count.persist()
# Write Outputs operator_kpis.write.mode("overwrite").parquet("output/operator_kpis") drop_rate_operator.write.mode("overwrite").parquet("output/drop_rate_operator"
)
drop_rate_circle.write.mode("overwrite").parquet("output/drop_rate_circle")
peak_hours.write.mode("overwrite").parquet("output/peak_hours") call_type_dist.write.mode("overwrite").parquet("output/call_type_dist") heavy_users.write.mode("overwrite").parquet("output/heavy_users") top_users.write.mode("overwrite").parquet("output/top_users") usage_category_dist.write.mode("overwrite").parquet("output/usage_category_di st")

spark.stop()


